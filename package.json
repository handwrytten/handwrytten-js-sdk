{
  "name": "handwrytten",
  "version": "1.3.0",
  "description": "Official TypeScript SDK for the Handwrytten API — send real handwritten notes at scale using robots with real pens.",
  "author": "Handwrytten",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handwrytten/handwrytten-js-sdk.git"
  },
  "keywords": [
    "handwrytten",
    "handwritten",
    "notes",
    "cards",
    "api",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
